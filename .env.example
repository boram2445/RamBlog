# --- Sanity ---
# Sanity 프로젝트 ID (https://www.sanity.io/manage)
SANITY_PROJECT_ID=
# 데이터셋 이름 (보통 production)
SANITY_DATASET=
# 자산 업로드/뮤테이션용 write 토큰
SANITY_SECRET_TOKEN=

# --- NextAuth ---
# 배포 환경: https://your-domain.com / 로컬: http://localhost:3000
NEXTAUTH_URL=
# JWT 서명용 시크릿 — `openssl rand -base64 32` 로 생성
NEXTAUTH_SECRET=

# --- Google OAuth ---
# Google Cloud Console → OAuth 2.0 Client IDs
GOOGLE_OAUTH_ID=
GOOGLE_OAUTH_SECRET=

# --- SEO (선택) ---
# Google Search Console 사이트 인증용 메타 태그 값
GOOGLE_VERIFICATION_ID=
