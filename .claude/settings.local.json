      "Bash(curl -sI https://ram-blog.vercel.app/sitemap-0.xml)",
      "Bash(curl -sI -A \"Mozilla/5.0 \\(compatible; Googlebot/2.1; +http://www.google.com/bot.html\\)\" https://ram-blog.vercel.app/sitemap.xml)",
      "Bash(curl -s -A \"Mozilla/5.0 \\(compatible; Googlebot/2.1; +http://www.google.com/bot.html\\)\" https://ram-blog.vercel.app/robots.txt)",
      "Bash(curl -s https://ram-blog.vercel.app/sitemap.xml)",
